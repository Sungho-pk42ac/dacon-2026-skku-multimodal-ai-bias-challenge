# 환경변수 예시 — 실제 키는 여기 넣지 말 것! pod에서 직접 export 하세요.
# 사용법(pod): `cp infra/env.example .env && nano .env` 후 `set -a; source .env; set +a`
# .env 는 .gitignore 로 제외됨. 절대 커밋 금지.

# Weights & Biases (학습 로그)
export WANDB_API_KEY=""          # wandb.ai 에서 발급. 또는 `wandb login` 사용
export WANDB_PROJECT="dacon-bias-challenge"

# HuggingFace (게이트 모델 다운로드 / private repo 업로드)
export HF_TOKEN=""               # huggingface.co/settings/tokens. 또는 `huggingface-cli login`
export HF_USERNAME="psh3333"     # 업로드 경로용 (비밀 아님)

# HF 캐시를 Volume으로 (Container 디스크 보호)
export HF_HOME="/workspace/hf_cache"

# (data_build 단계 전용 — 추론과 분리) 학습데이터 합성용
export OPENAI_API_KEY=""         # C방식 데이터 생성 시에만. 추론 코드엔 절대 미사용
